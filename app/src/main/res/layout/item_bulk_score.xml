<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="10dp"
    android:gravity="center_vertical"
    android:background="@color/card_light">

    <!-- Avatar -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="36dp" android:layout_height="36dp"
        android:layout_marginEnd="10dp"
        app:cardCornerRadius="18dp" app:cardElevation="0dp"
        app:cardBackgroundColor="@color/primary_light">
        <TextView android:id="@+id/tvBulkInitials"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:gravity="center" android:textSize="14sp" android:textStyle="bold"
            android:textColor="@color/primary" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Tên học sinh -->
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tvBulkName"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="13sp" android:textStyle="bold" android:textColor="@color/text_primary" />
        <TextView android:id="@+id/tvBulkCode"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="11sp" android:textColor="@color/text_secondary" />
    </LinearLayout>

    <!-- 3 field nhập điểm nhỏ -->
    <EditText android:id="@+id/edtBulkQT"
        android:layout_width="48dp" android:layout_height="36dp"
        android:hint="QT" android:inputType="numberDecimal"
        android:textSize="12sp" android:gravity="center"
        android:background="@drawable/bg_input_small"
        android:layout_marginStart="4dp" />
    <EditText android:id="@+id/edtBulkGK"
        android:layout_width="48dp" android:layout_height="36dp"
        android:hint="GK" android:inputType="numberDecimal"
        android:textSize="12sp" android:gravity="center"
        android:background="@drawable/bg_input_small"
        android:layout_marginStart="4dp" />
    <EditText android:id="@+id/edtBulkCK"
        android:layout_width="48dp" android:layout_height="36dp"
        android:hint="CK" android:inputType="numberDecimal"
        android:textSize="12sp" android:gravity="center"
        android:background="@drawable/bg_input_small"
        android:layout_marginStart="4dp" />

    <!-- Preview điểm -->
    <TextView android:id="@+id/tvBulkPreview"
        android:layout_width="40dp" android:layout_height="wrap_content"
        android:textSize="14sp" android:textStyle="bold"
        android:textColor="@color/primary" android:gravity="center"
        android:layout_marginStart="6dp" android:text="--" />
</LinearLayout>
