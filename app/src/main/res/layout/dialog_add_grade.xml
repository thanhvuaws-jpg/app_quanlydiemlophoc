<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/card_light"
    android:paddingTop="8dp"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingBottom="24dp">

    <!-- Drag Handle Indicator -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="#CBD5E1"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Thêm môn học mới"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="16dp" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Tên môn học -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="Tên môn học"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                app:boxCornerRadiusTopStart="10dp" app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp" app:boxCornerRadiusBottomEnd="10dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtSubject"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Học kỳ & Số tín chỉ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp"
                android:weightSum="2">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layoutSemester"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.2"
                    android:layout_marginEnd="6dp"
                    android:hint="Học kỳ (VD: HK1 2024-2025)"
                    app:boxCornerRadiusTopStart="10dp" app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp" app:boxCornerRadiusBottomEnd="10dp">
                    <AutoCompleteTextView
                        android:id="@+id/actvSemester"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.8"
                    android:layout_marginStart="6dp"
                    android:hint="Tín chỉ"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                    app:boxCornerRadiusTopStart="10dp" app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp" app:boxCornerRadiusBottomEnd="10dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtCredits"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:text="3" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <!-- Điểm quá trình & Tỷ lệ % -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp"
                android:weightSum="2">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.2"
                    android:layout_marginEnd="6dp"
                    android:hint="Điểm quá trình (QT)"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                    app:boxCornerRadiusTopStart="10dp" app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp" app:boxCornerRadiusBottomEnd="10dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtScoreQT"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.8"
                    android:layout_marginStart="6dp"
                    android:hint="Tỷ lệ QT %"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                    app:boxCornerRadiusTopStart="10dp" app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp" app:boxCornerRadiusBottomEnd="10dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtWeightQT"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:text="50" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <!-- Điểm cuối kỳ & Tỷ lệ % -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp"
                android:weightSum="2">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.2"
                    android:layout_marginEnd="6dp"
                    android:hint="Điểm cuối kỳ (CK)"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                    app:boxCornerRadiusTopStart="10dp" app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp" app:boxCornerRadiusBottomEnd="10dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtScoreCK"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.8"
                    android:layout_marginStart="6dp"
                    android:hint="Tỷ lệ CK %"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                    app:boxCornerRadiusTopStart="10dp" app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp" app:boxCornerRadiusBottomEnd="10dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtWeightCK"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:text="50" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveScore"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Lưu điểm môn học"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                app:backgroundTint="@color/primary"
                android:layout_marginBottom="16dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
